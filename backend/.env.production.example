# Production Environment Template
# Duplicate this file as .env and fill in official production values

PORT=5000
NODE_ENV=production

# Official MongoDB Atlas URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/jvit_library?retryWrites=true&w=majority

# Secure JWT Keys
JWT_SECRET=<your_secure_jwt_secret>
JWT_EXPIRE=2d

# Official Razorpay Keys
RAZORPAY_KEY_ID=<official_key_id>
RAZORPAY_KEY_SECRET=<official_key_secret>

# Official Stripe Keys
STRIPE_SECRET_KEY=<official_stripe_secret>
STRIPE_PUBLISHABLE_KEY=<official_stripe_pub>

# Official Mailer (Brevo)
EMAIL_USER=<your_email@gmail.com>
BREVO_API_KEY=<your_brevo_api_key>
EMAIL_FROM=JVIT Library Admin <your_email@gmail.com>
NOTIFICATION_EMAIL=<your_email@gmail.com> # Email to receive system alerts

# Official Domain
FRONTEND_URL=https://library.jvit.edu.in
